generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  mcpApiKeys    McpApiKey[]
  products      Product[]
  uploadRecords UploadRecord[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Product {
  id          Int              @id @default(autoincrement())
  ownerId     String
  key         String
  name        String
  description String?
  createdAt   DateTime         @default(now())
  owner       User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  mcpApiKeyProducts McpApiKeyProduct[]
  versions    ProductVersion[]

  @@unique([ownerId, key])
}

model ProductVersion {
  id          Int          @id @default(autoincrement())
  productId   Int
  version     String
  title       String?
  remark      String?
  storagePath String
  entryUrl    String
  status      String
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceSnapshot SourceSnapshot?

  @@unique([productId, version])
}

model SourceSnapshot {
  id          Int            @id @default(autoincrement())
  versionId   Int            @unique
  status      String
  rootPath    String
  fileCount   Int            @default(0)
  totalBytes  Int            @default(0)
  generatedAt DateTime?
  errorMessage String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  version     ProductVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
}

model UploadRecord {
  id           Int      @id @default(autoincrement())
  userId       String
  productKey   String
  version      String
  fileName     String
  fileSize     Int
  status       String
  currentStep  String?
  stepsJson    String?
  logSummary   String?
  errorMessage String?
  sourceArchivePath String?
  workspacePath String?
  publishedPath String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model McpApiKey {
  id              Int                @id @default(autoincrement())
  userId          String
  name            String
  tokenHash       String             @unique
  tokenCiphertext String
  tokenPrefix     String
  tokenSuffix     String
  expiresAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  productGrants   McpApiKeyProduct[]
}

model McpApiKeyProduct {
  apiKeyId Int
  productId Int
  apiKey   McpApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([apiKeyId, productId])
  @@index([productId])
}
